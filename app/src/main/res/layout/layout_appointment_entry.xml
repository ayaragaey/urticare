<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:layout_marginBottom="16dp"
    android:background="#11FFFFFF">

    <TextView
        android:id="@+id/label_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="12sp"
        android:text="@string/label_doctor_app"/>

    <EditText
        android:id="@+id/edit_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#82B1FF"
        android:textSize="14sp"
        android:hint="@string/hint_name_desc"
        android:backgroundTint="@color/white"
        android:inputType="text"
        android:autofillHints="none"/>

    <TextView
        android:id="@+id/txt_date_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="italic"
        android:layout_marginTop="4dp"
        android:text="@string/status_no_date"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_select_date"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_select_date"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:background="@drawable/pill_button_selector"
            android:textAllCaps="false"
            android:minWidth="80dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_repeat"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_repeat_rem"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:background="@drawable/pill_button_selector"
            android:textAllCaps="false"
            android:layout_marginStart="8dp"
            android:minWidth="100dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_remind"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_remind_me"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:background="@drawable/pill_button_selector"
            android:textAllCaps="false"
            android:minWidth="80dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_clear"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/grey_button_selector"
            android:textAllCaps="false"
            android:layout_marginStart="8dp"
            android:minWidth="60dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_undo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="↶"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:background="@drawable/grey_button_selector"
            android:textAllCaps="false"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>