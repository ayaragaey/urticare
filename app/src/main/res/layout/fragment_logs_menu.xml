<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/activity_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/button_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="58dp"
        android:layout_marginStart="16dp"
        android:text="@string/back_arrow"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:elevation="10dp"/>

    <TextView
        android:id="@+id/logs_menu_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_logs"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="110dp"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/logs_menu_title"
        android:layout_centerHorizontal="true"
        android:orientation="vertical"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_pills_log"
            android:layout_width="240dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/tab_log"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_flare_log"
            android:layout_width="240dp"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/tab_flare_log"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_xolair_log"
            android:layout_width="240dp"
            android:layout_height="48dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/tab_xolair_log"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="@string/copyright_notice"
        android:textColor="@color/white"
        android:textSize="8sp" />

</RelativeLayout>