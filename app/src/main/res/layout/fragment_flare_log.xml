<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Manual, Export and Controlled buttons row -->
    <LinearLayout
        android:id="@+id/flare_secondary_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_manual_flare"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/btn_manual_entry"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_export_flare_csv"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/export_csv"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_log_controlled"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/controlled_button_label"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/flare_button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/flare_secondary_buttons"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_clear_flare"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/reset_history"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_undo_clear_flare"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/undo_clear"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:visibility="gone"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_reset_flare_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/flare_button_selector"
            android:text="@string/reset_all"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/flare_button_container">

        <LinearLayout
            android:id="@+id/flare_log_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="@string/copyright_notice"
        android:textColor="@color/white"
        android:textSize="8sp" />

</RelativeLayout>