<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/xolair_action_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_xolair_manual"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/btn_manual_entry"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_xolair_300"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/xolair_300"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_xolair_150"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/xolair_150"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_xolair_alternative"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/alternative_label"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_alternative_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/xolair_action_container"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/edit_alternative_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type alternative name..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_secondary_grey"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_save_alternative"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/pill_button_selector"
            android:text="@string/save_label"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/xolair_tool_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/container_alternative_input"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_export_xolair"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/grey_button_selector"
            android:text="@string/export_csv"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_clear_xolair"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/grey_button_selector"
            android:text="@string/reset_history"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_undo_clear_xolair"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/grey_button_selector"
            android:text="@string/undo_clear"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:visibility="gone"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_reset_xolair_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/grey_button_selector"
            android:text="@string/reset_all"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/xolair_tool_container">

        <LinearLayout
            android:id="@+id/xolair_log_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="@string/copyright_notice"
        android:textColor="@color/white"
        android:textSize="8sp" />

</RelativeLayout>